{
  "manifest_version": 3,
  "name": "抖音媒体数据助手",
  "version": "1.0.1",
  "description": "基于原生拦截与 IndexedDB 的抖音视频与图文无水印下载工具",
  "permissions": [
    "storage",
    "downloads",
    "activeTab"
  ],
  "host_permissions": [
    "http://www.douyin.com/*",
    "https://www.douyin.com/*",
    "https://*.douyin.com/*",
    "http://localhost/*",
    "https://localhost/*",
    "http://*/*",
    "https://*/*",
    "*://*/*",
    "*://*.douyin.com/*",
    "https://www.douyin.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "下载当前看选项"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>",
        "http://*/*",
        "https://*/*",
        "https://www.douyin.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
